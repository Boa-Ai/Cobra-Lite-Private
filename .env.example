# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here
FLASK_DEBUG=0

# Server Configuration
HOST=127.0.0.1
PORT=5001

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_SESSION_KEY=
OPENCLAW_SESSION_ID=cobra-lite
# Set to 0 (or negative) for unlimited run duration.
OPENCLAW_AGENT_TIMEOUT_SECONDS=0
# Set to 0 (or negative) for unlimited auto-continue retries when action limits are hit.
COBRA_AUTO_CONTINUE_MAX_ATTEMPTS=0
# Execution mode for this UI: cli_only blocks browser/web_* tool usage
COBRA_EXECUTION_MODE=cli_only
# Enabled by default: the agent attempts package-manager installs for missing commands
COBRA_AUTO_INSTALL_TOOLS=1

# Chat History Limits
CHAT_HISTORY_MAX_MESSAGES=2000
CHAT_HISTORY_MAX_CHARS=240000

# State File Location (optional)
STATE_FILE=.claw_state.json
